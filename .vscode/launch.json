{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API (NestJS)",
      "cwd": "${workspaceFolder}/apps/api",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["run", "dev", "--", "--debug"],
      "console": "externalTerminal",
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "autoAttachChildProcesses": true
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug CLI (Ink)",
      "cwd": "${workspaceFolder}/apps/cli",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx",
        "--inspect",
        "src/index.tsx"
      ],
      "console": "externalTerminal",
      "skipFiles": ["<node_internals>/**"],
      "autoAttachChildProcesses": true
    }
  ],
  "compounds": [
    {
      "name": "Full Application",
      "configurations": ["Debug API (NestJS)", "Debug CLI (Ink)"]
    }
  ]
}
